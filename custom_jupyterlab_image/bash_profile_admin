# Admin container bash profile
# Automatically shows SSH connection info when terminal opens

# Source the default profile first
if [ -f ~/.bashrc ]; then
    source ~/.bashrc
fi

# Function to show SSH connection info
show_ssh_info() {
    echo ""
    echo "🔐 SSH Connection Info for Your Local Machine"
    echo "============================================="
    echo "📂 SSH keys are auto-generated and saved in your work directory!"
    echo ""
    
    # Show SSH key files in work directory
    if [ -f /home/jovyan/work/ssh_private_key ]; then
        echo "🔑 Private key: /home/jovyan/work/ssh_private_key" 
        echo "🔓 Public key:  /home/jovyan/work/ssh_public_key"
        echo ""
    fi
    
    # Get container info
    CONTAINER_ID=$(hostname)
    CONTAINER_IP=$(hostname -I | awk '{print $1}')
    
    # Check for external port mapping
    PORT_MAPPING=$(docker port $CONTAINER_ID 22/tcp 2>/dev/null || echo "none")
    
    echo "📍 Container: $CONTAINER_ID"
    echo "🌐 Internal IP: $CONTAINER_IP"
    
    # Show SSH config based on available connection method
    echo ""
    echo "📝 Add this to ~/.ssh/config on your LOCAL machine:"
    echo "---------------------------------------------------"
    
    if [[ "$PORT_MAPPING" != "none" && "$PORT_MAPPING" == *":"* ]]; then
        # External port available
        EXTERNAL_PORT=$(echo $PORT_MAPPING | cut -d: -f2)
        cat << EOF
Host jupyterlab-admin
    HostName hedgeiot
    Port $EXTERNAL_PORT
    User jovyan
    IdentityFile ~/.ssh/jupyterlab-admin
    ProxyCommand ssh -W localhost:$EXTERNAL_PORT hedgeiot
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
EOF
    else
        # Use internal IP
        cat << EOF
Host jupyterlab-admin
    HostName $CONTAINER_IP
    Port 22
    User jovyan
    IdentityFile ~/.ssh/jupyterlab-admin
    ProxyCommand ssh -W $CONTAINER_IP:22 hedgeiot
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
EOF
    fi
    
    echo "---------------------------------------------------"
    echo ""
    echo "🔑 Get SSH private key from this container:"
    echo "   cat /home/jovyan/work/ssh_private_key"
    echo ""
    echo "🚀 Then connect from your laptop:"
    echo "   ssh jupyterlab-admin"
    echo ""
    echo "🎯 For Cursor IDE: Remote-SSH → jupyterlab-admin"
    echo "   Working directory: /home/jovyan/work"
    echo ""
}

# Only show SSH info if this is an interactive shell and we haven't shown it yet
if [[ $- == *i* ]] && [[ -z "$SSH_INFO_SHOWN" ]]; then
    show_ssh_info
    export SSH_INFO_SHOWN=1
fi

# Add some useful aliases for admin
alias ll='ls -la'
alias la='ls -la'
alias ssh-info='show_ssh_info'
alias shared='cd /home/jovyan/work/shared_data'
alias notebooks='cd /home/jovyan/work'

# Set nice prompt
export PS1='\[\033[01;32m\]admin@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '

echo "💡 Tip: Type 'ssh-info' to show SSH connection details again"
